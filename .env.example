# Slopshop Environment Variables
# Copy to .env and fill in your values.
# The server starts with ZERO config — 925 pure-compute handlers work out of the box.

# ─── AI / LLM ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROK_API_KEY=xai-...
DEEPSEEK_API_KEY=...
OLLAMA_HOST=http://localhost:11434

# ─── EXTERNAL SERVICES ───────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
GITHUB_TOKEN=ghp_...
LINEAR_API_KEY=lin_api_...
SLACK_BOT_TOKEN=xoxb-...

# ─── AWS / S3 ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# ─── AGENT IDENTITY ──────────────────────────────────────────────────────────
INTERNAL_SECRET=                      # JWT signing for SVID tokens (auto-generated if blank)

# ─── DATABASE ────────────────────────────────────────────────────────────────
DB_PATH=/data/slopshop.db             # Railway: mount volume at /data
                                      # Local default: .data/slopshop.db

# ─── BILLING ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
POLAR_ACCESS_TOKEN=...

# ─── ORCHESTRATION ───────────────────────────────────────────────────────────
ORCHESTRATE_API_KEY=sk-slop-...       # Defaults to demo key if not set

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
