# Slopshop Environment Variables
# Copy to .env and fill in your values.
# The server starts with ZERO config — 925 pure-compute handlers + memory work out of the box.
# Add API keys to unlock each intelligence tier.

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Dream Engine (REM memory synthesis) + Research system use these keys
ANTHROPIC_API_KEY=sk-ant-...      # Claude — synthesis, analysis, Dream Engine core
OPENAI_API_KEY=sk-...             # GPT-4o — academic depth, creative connections
XAI_API_KEY=xai-...               # Grok — real-time X/Twitter + Japanese X (日本語)
GROK_API_KEY=                     # Alias for XAI_API_KEY (either works)
DEEPSEEK_API_KEY=...              # DeepSeek — 小红书/知乎/微信/B站 Chinese internet intelligence
OLLAMA_HOST=http://localhost:11434 # Local models (Llama, Mistral, Qwen, etc.) — no cost

# ─── RUSSIAN INTELLIGENCE (Optional) ─────────────────────────────────────────
# Yandex/Telegram/VK research — if not set, Claude/GPT will handle Russian-language research
YANDEX_API_KEY=                   # YandexGPT API key (IAM token or API key)
YANDEX_FOLDER_ID=                 # Yandex Cloud folder ID (required with YANDEX_API_KEY)

# ─── EXTERNAL SERVICES ───────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
GITHUB_TOKEN=ghp_...
LINEAR_API_KEY=lin_api_...
SLACK_BOT_TOKEN=xoxb-...

# ─── AWS / S3 ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# ─── AGENT IDENTITY ──────────────────────────────────────────────────────────
INTERNAL_SECRET=                      # JWT signing for SVID tokens (auto-generated if blank)

# ─── DATABASE ────────────────────────────────────────────────────────────────
DB_PATH=/data/slopshop.db             # Railway: mount volume at /data
                                      # Local default: .data/slopshop.db

# ─── BILLING ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
POLAR_ACCESS_TOKEN=...

# ─── ORCHESTRATION ───────────────────────────────────────────────────────────
ORCHESTRATE_API_KEY=sk-slop-...       # Defaults to demo key if not set
BASE_URL=https://your-domain.com      # For invite links, webhooks, public URLs

# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── MEMORY CONFIGURATION ────────────────────────────────────────────────────
# Memory works out of the box with zero config (SQLite-backed)
# Compression is automatic for values > 512 bytes
# Dream Engine schedules can be set via POST /v1/memory/dream/schedule

# ─── QUICK CAPABILITY MATRIX ─────────────────────────────────────────────────
# Zero keys:     925 pure-compute APIs + full memory layer (free)
# +Claude:       Dream Engine synthesis, research, AI chat
# +Grok:         Real-time X/Twitter feed + Japanese X intelligence
# +DeepSeek:     Chinese internet (小红书/知乎/微信/B站)
# +OpenAI:       Academic + technical depth research
# +Yandex:       Russian web (Яндекс/Telegram/VK)
# All 5 keys:    Planet-tier research — full internet across every language
