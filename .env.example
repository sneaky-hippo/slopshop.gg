# Slopshop Configuration
# Copy this to .env and fill in your values

# Server
PORT=3000
NODE_ENV=production

# Database (SQLite path)
DB_PATH=.data/slopshop.db

# LLM Providers (optional — unlocks AI-powered APIs)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Payments (optional — enables real checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Alternative payments
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=

# Admin (required for /v1/admin/* endpoints)
ADMIN_SECRET=

# External integrations (all optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
GITHUB_TOKEN=
SENDGRID_API_KEY=
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTION_API_KEY=
LINEAR_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CX=

# AWS S3 (optional — for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# CORS (optional — default allows all origins)
CORS_ORIGIN=*
