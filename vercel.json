{
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600, stale-while-revalidate=86400" }]
    },
    { "source": "/sitemap.xml", "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }] },
    { "source": "/llms.txt", "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }] }
  ],
  "redirects": [
    { "source": "/developer", "destination": "/dev-console", "permanent": false },
    { "source": "/dashboard", "destination": "/brain", "permanent": false },
    { "source": "/dashboard.html", "destination": "/brain", "permanent": true },
    { "source": "/signup", "destination": "/home", "permanent": false },
    { "source": "/login", "destination": "/home", "permanent": false },
    { "source": "/consumer", "destination": "/remlabs", "permanent": true },
    { "source": "/_internal/(.*)", "destination": "/404", "permanent": false },
    { "source": "/research-os", "destination": "/research-os", "permanent": false },
    { "source": "/finance-os", "destination": "/finance-os", "permanent": false },
    { "source": "/legal-os", "destination": "/legal-os", "permanent": false },
    { "source": "/creative-os", "destination": "/creative-os", "permanent": false }
  ],
  "rewrites": [
    { "source": "/developers", "destination": "/home" },
    { "source": "/v1/:path*", "destination": "https://slopshop-production.up.railway.app/v1/:path*" },
    { "source": "/auth/:path*", "destination": "https://slopshop-production.up.railway.app/auth/:path*" },
    { "source": "/zapier/:path*", "destination": "https://slopshop-production.up.railway.app/zapier/:path*" },
    { "source": "/.well-known/:path*", "destination": "https://slopshop-production.up.railway.app/.well-known/:path*" }
  ]
}
